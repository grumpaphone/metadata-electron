{
	"compilerOptions": {
		"target": "ES2022",
		"module": "commonjs",
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"baseUrl": ".",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"noImplicitAny": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"allowJs": true
		// TODO: enable "noUncheckedIndexedAccess": true once existing index access
		// patterns are cleaned up. A trial produced >20 errors across src/, so it
		// is deferred to a follow-up. "strict: true" is prioritized here.
	},
	"include": ["src/**/*", "src/font-declarations.d.ts"],
	"exclude": ["node_modules/**/*"]
}
